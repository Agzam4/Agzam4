---
import Base from '../layouts/Base.astro';
---

<Base title="404 - Not Found" description="Page not found" locale="en">
  <div class="container">
    <h1>404</h1>
    <p>Page not found</p>
    <a href="/en/">← Back to portfolio</a>
  </div>
</Base>

<style>
  .container {
    text-align: center;
    padding-top: 120px;
  }
  h1 {
    font-size: 72px;
    color: #e0e0e0;
    margin-bottom: 16px;
  }
  p {
    color: #888;
    margin-bottom: 24px;
  }
</style>
