---
// Redirect to language-specific page based on browser language preference
const base = import.meta.env.BASE_URL;
---

<html>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${base}en/`} />
    <link rel="canonical" href={`${base}en/`} />
  </head>
  <body>
    <script is:inline>
      // Detect browser language preference
      const browserLang = navigator.language || navigator.userLanguage || 'en';
      const lang = browserLang.startsWith('ru') ? 'ru' : 'en';
      const base = import.meta.env?.BASE_URL || '/Agzam4/';
      window.location.replace(`${base}${lang}/`);
    </script>
    <noscript>
      <meta http-equiv="refresh" content={`0;url=${base}en/`} />
    </noscript>
  </body>
</html>
